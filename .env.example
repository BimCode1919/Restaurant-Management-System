# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/restaurant_qr_db
DB_USERNAME=restaurant_user
DB_PASSWORD=restaurant_pass

# JWT Configuration
JWT_SECRET=MySecretKeyForRestaurantQROrderSystemMinimum256BitsLongForHS256Algorithm
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# MoMo Payment Gateway Configuration
# Get your credentials from: https://business.momo.vn/
MOMO_PARTNER_CODE=MOMOXXXX2023
MOMO_ACCESS_KEY=your_access_key_here
MOMO_SECRET_KEY=your_secret_key_here
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create

# MoMo Callback URLs (IMPORTANT: Must be publicly accessible for production)
# For development, use ngrok or similar tunneling service
MOMO_RETURN_URL=http://localhost:8080/api/payments/momo/return
MOMO_NOTIFY_URL=https://your-ngrok-url.ngrok.io/api/payments/momo/notify

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TIMEOUT=60000

# Application Configuration
APP_BASE_URL=http://localhost:3000
APP_QR_BASE_URL=http://localhost:3000
APP_QR_IMAGE_PATH=./qr-codes/

# CORS Configuration
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# File Upload Configuration
APP_FILE_UPLOAD_DIR=./uploads/
APP_FILE_MAX_SIZE=10485760

# Server Configuration
SERVER_PORT=8080
SERVER_CONTEXT_PATH=/api

# Logging Level
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_APP=DEBUG
LOGGING_LEVEL_WEB=DEBUG
LOGGING_LEVEL_SQL=DEBUG
