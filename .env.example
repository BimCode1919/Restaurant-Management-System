# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TIMEOUT=60000

# Application Configuration
APP_BASE_URL=http://localhost:3000
APP_QR_BASE_URL=http://localhost:3000
APP_QR_IMAGE_PATH=./qr-codes/

# CORS Configuration
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# File Upload Configuration
APP_FILE_UPLOAD_DIR=./uploads/
APP_FILE_MAX_SIZE=10485760

# Server Configuration
SERVER_PORT=8080
SERVER_CONTEXT_PATH=/api

# Ngrok Configuration (for exposing local backend to internet)
# Get your authtoken from: https://dashboard.ngrok.com/get-started/your-authtoken
# Required for MoMo IPN callback in local development
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# Logging Level
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_APP=DEBUG
LOGGING_LEVEL_WEB=DEBUG
LOGGING_LEVEL_SQL=DEBUG
